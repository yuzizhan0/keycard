{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Keycard",
  "version": "0.1.0",
  "identifier": "app.keycard.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Keycard",
        "width": 920,
        "height": 720
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false
  }
}
